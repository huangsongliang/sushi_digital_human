{
  "commands": [
    {
      "name": "代码规范检查",
      "description": "运行flake8检查代码风格",
      "command": "uv run flake8 backend/ --max-line-length=120",
      "working_directory": "${workspace}",
      "type": "shell",
      "icon": "check-circle"
    },
    {
      "name": "自动修复代码",
      "description": "自动修复Python/Vue代码规范问题",
      "command": "python scripts/auto_fix.py",
      "working_directory": "${workspace}",
      "type": "shell",
      "icon": "wrench"
    },
    {
      "name": "运行单元测试",
      "description": "运行所有单元测试",
      "command": "uv run pytest tests/unit/ -v",
      "working_directory": "${workspace}",
      "type": "shell",
      "icon": "play"
    },
    {
      "name": "启动后端服务",
      "description": "启动FastAPI开发服务器",
      "command": "uv run uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload",
      "working_directory": "${workspace}",
      "type": "shell",
      "icon": "server",
      "is_long_running": true
    },
    {
      "name": "启动前端服务",
      "description": "启动Vue开发服务器",
      "command": "cd frontend && npm run dev",
      "working_directory": "${workspace}",
      "type": "shell",
      "icon": "globe",
      "is_long_running": true
    }
  ]
}